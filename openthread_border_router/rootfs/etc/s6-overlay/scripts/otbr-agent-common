# shellcheck shell=bash
# shellcheck disable=SC2034

declare thread_if
declare otbr_forward_ingress_chain
declare otbr_forward_egress_chain
declare otbr_forward_nat64_chain
declare otbr_fw_mark

thread_if="$(bashio::config 'thread_interface')"
bashio::log.info "Thread interface configured: ${thread_if}"

# Store the interface name for other scripts to use
echo "${thread_if}" > /tmp/otbr-thread-interface

# Create unique firewall chain names based on the interface
# This allows multiple OTBR instances to coexist with separate firewall rules
otbr_forward_ingress_chain="OTBR_FORWARD_INGRESS_${thread_if}"
otbr_forward_egress_chain="OTBR_FORWARD_EGRESS_${thread_if}"
otbr_forward_nat64_chain="OTBR_FORWARD_NAT64_${thread_if}"
otbr_fw_mark="0x1001"
